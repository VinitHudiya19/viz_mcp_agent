# ── viz_mcp_agent environment variables ──────────────────────────────────────
# Copy this file to .env and fill in the values.

# E2B Sandbox API key (required ONLY if using sandbox execution)
# Get yours at: https://e2b.dev
# If running charts locally (no sandbox), this is NOT needed.
E2B_API_KEY=

# Optional: E2B sandbox config
SANDBOX_TIMEOUT=300
SANDBOX_TEMPLATE=base
